# ── JobGati Frontend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values.

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Google Gemini API key (used by backend for AI interview & learning path)
# Get one at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# (Optional) Grok / OpenAI API key if used as fallback for interview AI
VITE_OPENAI_API_KEY=

# App name & meta
VITE_APP_NAME=JobGati
